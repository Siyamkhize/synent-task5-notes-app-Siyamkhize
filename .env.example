# Flask configuration
SECRET_KEY=dev_key_change_me_in_production
FLASK_APP=app.py
FLASK_DEBUG=1

# Database configuration
# For XAMPP with default MySQL port 3306:
DATABASE_URL=mysql+pymysql://root@localhost/notes_db

# If your MySQL server is on a different port (e.g. 3307):
# DATABASE_URL=mysql+pymysql://root@localhost:3307/notes_db

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Mail (optional for reminders)
MAIL_ENABLED=
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SENDER=
